      "question_options": [
        {"label": "A", "content": "对于任意ε>0，存在N，使得当n>N时，|an - L| < ε", "is_correct": true},
        {"label": "B", "content": "对于任意ε>0，存在N，使得当n<N时，|an - L| < ε", "is_correct": false},
        {"label": "C", "content": "数列{an}的所有项都等于L", "is_correct": false},
