      "point_id": 3,
      "question_type": "single_choice",
      "question_content": "以下哪个选项最能准确描述质数的定义？",
      "question_options": [
        {"label": "A", "content": "大于1且只有1和它本身两个正因数的数", "is_correct": true},
        {"label": "B", "content": "可以被2整除的数", "is_correct": false},
        {"label": "C", "content": "任何大于0的自然数", "is_correct": false},
        {"label": "D", "content": "能够分解为多个因子的数", "is_correct": false}
      ],
      "correct_answer": "A",
      "explanation": "质数是指大于1的自然数，且只能被1和它本身整除。例如，2、3、5是质数，而4、6不是。",
      "difficulty_level": "easy",
      "score_points": 1.0
    },
    {
      "point_id": 3,
      "question_type": "fill_blank",
      "question_content": "在1到10之间，既是偶数又是质数的数是：_____。",
      "question_options": null,
      "correct_answer": "2",
      "explanation": "在1到10之间的质数包括2、3、5、7，其中只有2是偶数，因此答案是2。",
      "difficulty_level": "medium",
      "score_points": 1.5
    },
    {
      "point_id": 4,
      "question_type": "true_false",
      "question_content": "所有的奇数都是质数。",
      "question_options": [
        {"label": "A", "content": "正确", "is_correct": false},
        {"label": "B", "content": "错误", "is_correct": true}
      ],
      "correct_answer": "B",
      "explanation": "并非所有奇数都是质数。例如，9是奇数，但它不是质数，因为它有因数1、3和9。",
      "difficulty_level": "easy",
      "score_points": 1.0
    },
    {
      "point_id": 4,
      "question_type": "multiple_choice",
      "question_content": "以下哪些数是合数？（多选）",
      "question_options": [
        {"label": "A", "content": "4", "is_correct": true},
        {"label": "B", "content": "7", "is_correct": false},
        {"label": "C", "content": "9", "is_correct": true},
        {"label": "D", "content": "11", "is_correct": false},
        {"label": "E", "content": "15", "is_correct": true}
      ],
      "correct_answer": ["A", "C", "E"],
      "explanation": "合数是可以分解为多个因子的数。4可以分解为1×4或2×2，9可以分解为1×9或3×3，15可以分解为1×15或3×5，因此它们是合数。而7和11是质数。",
      "difficulty_level": "medium",
      "score_points": 2.0
    }
  ]
}
